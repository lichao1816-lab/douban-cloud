# ============================================================
# 阿尔戈斯计划 · 豆瓣云端 环境变量模板
# 拷贝本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略,不会进仓库。
# ============================================================

# --- Supabase(在 Supabase 控制台 → Project Settings → API 找到)---
SUPABASE_URL=https://你的项目.supabase.co
SUPABASE_ANON_KEY=你的-anon-public-key            # 前端用(只读+受限写),可公开
SUPABASE_SERVICE_ROLE_KEY=你的-service-role-key    # 抓取脚本用,务必保密!!!

# --- 豆瓣 cookie(从浏览器复制整段 Cookie 请求头;见 SETUP-macmini.md)---
DOUBAN_COOKIE=bid=xxxx; ll="xxxx"; dbcl2="xxxx"; ...

# --- 住宅代理(可空)。Mac mini 家用住宅IP 可不填;
#     GitHub Actions 机房IP 抓豆瓣大概率被封,必须填住宅代理。---
# 格式: http://用户名:密码@主机:端口   或   http://主机:端口
DOUBAN_PROXY=
